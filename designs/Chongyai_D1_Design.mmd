classDiagram

class User {
  +userId: UUID
  +name: string
  +email: string
  +phone: string
  +citizenId: string
  +passwordHash: string
  +status: AccountStatus
  +createdAt: datetime
  +updateProfile()
  +suspendAccount()
}

class Applicant {
  +education: string
  +age: int
  +skills: string[]
  +experience: string
  +preferredJobType: string
  +searchJob()
  +applyJob()
  +bookmarkJob()
}

class RecruitmentUnit {
  +companyName: string
  +companyAddress: string
  +industry: string
  +createJobAnnouncement()
  +reviewApplicant()
  +scheduleInterview()
}

class Administrator {
  +adminId: UUID
  +generateReport()
  +manageUsers()
  +viewSystemStatistics()
}

User <|-- Applicant
User <|-- RecruitmentUnit


class JobAnnouncement {
  +jobId: UUID
  +title: string
  +description: string
  +position: string
  +requiredAge: int
  +requiredEducation: string
  +salaryRange: string
  +location: string
  +viewCount: int
  +publishDate: datetime
  +publish()
}

RecruitmentUnit "1" --> "many" JobAnnouncement : posts

class JobApplication {
  +applicationId: UUID
  +applyDate: datetime
  +status: ApplicationStatus
  +submitApplication()
  +updateStatus()
}

Applicant "1" --> "many" JobApplication
JobAnnouncement "1" --> "many" JobApplication

class Interview {
  +interviewId: UUID
  +scheduledTime: datetime
  +meetingLink: string
  +recordingUrl: string
  +status: InterviewStatus
  +schedule()
  +recordInterview()
}

JobApplication "1" --> "0..1" Interview

class Payment {
  +paymentId: UUID
  +amountApplicant: float
  +amountRecruiter: float
  +totalAmount: float
  +paymentStatus: string
  +paymentDate: datetime
  +processPayment()
}

JobApplication "1" --> "1" Payment

class Bookmark {
  +bookmarkId: UUID
  +createdDate: datetime
}

Applicant "1" --> "many" Bookmark
Bookmark "many" --> "1" JobAnnouncement


class RecommendationEngine {
  +matchJobs(applicantProfile)
  +recommendApplicants(jobCriteria)
}

RecommendationEngine --> Applicant
RecommendationEngine --> JobAnnouncement


class Report {
  +reportId: UUID
  +month: int
  +year: int
  +generateStatistics()
  +visualizeData()
}

Administrator --> Report

class MOIIdentityAPI {
  +verifyCitizenID()
}

class BankingAPI {
  +processCreditCard()
}

User --> MOIIdentityAPI : verify identity
Payment --> BankingAPI : payment processing

class ChatbotService {
  +answerQuestion()
  +transferToHumanSupport()
}

User --> ChatbotService